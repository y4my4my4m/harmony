{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Harmony",
    "version": "1.3.0",
    "identifier": "online.knowmad.harmony",
    "build": {
      "beforeBuildCommand": "npm run build-only -- --mode production",
      "beforeDevCommand": "npm run dev -- --mode production",
      "devUrl": "http://localhost:5173",
      "frontendDist": "../dist"
    },
    "app": {
      "windows": [
        {
          "label": "main",
          "title": "Harmony",
          "width": 1280,
          "height": 720,
          "resizable": true,
          "fullscreen": false,
          "decorations": true,
          "transparent": false
        }
      ],
      "security": {
        "csp": "default-src 'self' blob: data: ipc: asset:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' wss: ws: https: http: ipc:; img-src 'self' blob: data: https: asset:; media-src 'self' blob: data: https: asset:; font-src 'self' data: asset:;",
        "dangerousDisableAssetCspModification": false,
        "assetProtocol": {
          "enable": true,
          "scope": ["**/*"]
        }
      },
      "withGlobalTauri": true
    },
    "bundle": {
      "active": false,
      "targets": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "publisher": "Knowmad",
      "copyright": "",
      "category": "SocialNetworking",
      "shortDescription": "Federated Discord-like chat app",
      "longDescription": "A federated, Discord-like chat application with real-time messaging, voice calls, and ActivityPub integration",
      "linux": {
        "deb": {
          "depends": []
        },
        "appimage": {
          "bundleMediaFramework": false
        }
      },
      "macOS": {
        "minimumSystemVersion": "10.13",
        "exceptionDomain": ""
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "en-US"
        }
      },
      "iOS": {
        "minimumSystemVersion": "13.0"
      },
      "android": {
        "minSdkVersion": 24
      }
    },
    "plugins": {}
  }
  