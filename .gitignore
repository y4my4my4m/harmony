# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
.DS_Store
dist
dist-ssr
coverage
*.local

# Rust / Tauri build output (subdir .gitignore covers git, this line is so
# top-level tools like eslint that read root .gitignore skip it too)
src-tauri/target/

# VitePress build output (cache is below)
docs/.vitepress/dist/

# Generated docs (npm run docs:generate-*).
# Run docs:generate-all to (re)build before docs:dev / docs:build.
docs/api/
docs/components/
docs/generated/
docs/guide/

/cypress/videos/
/cypress/screenshots/

# Cursor agent plans (local AI session artifacts)
.cursor/plans/

# Claude Code local settings
.claude/

# Lockfiles for package managers we don't standardize on (project uses npm)
bun.lockb

# -----------------------------------------------------------------------------
# Instance-customizable assets
# -----------------------------------------------------------------------------
# Background images: the repo ships a small default set; instance operators can
# drop additional .webp files into these folders before `npm run build` and
# the manifest builder will pick them up automatically. Only the explicitly
# tracked default-* files are committed.
public/backgrounds/login/*.webp
!public/backgrounds/login/1.webp
!public/backgrounds/login/2.webp
!public/backgrounds/login/3.webp
!public/backgrounds/login/4.webp
!public/backgrounds/login/5.webp
public/backgrounds/404/*.webp
!public/backgrounds/404/1.webp
!public/backgrounds/404/2.webp
public/backgrounds/offline/*.webp
!public/backgrounds/offline/1.webp
!public/backgrounds/offline/2.webp
# manifest.json is generated by scripts/build-background-manifest.mjs at build time
public/backgrounds/manifest.json

# Optional emoji packs: instance operators can drop their own packs under
# public/assets/emojis/<pack>/. The repo only ships Twemoji as a default.

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

*.tsbuildinfo


.env
.env.dev
.env.stg.
.env.prod
.env.production
.env.test

.venv/


docs/.vitepress/cache
docker
# docker-compose.yml

# Local dev certificates (generated by mkcert)
dev/certs/*.pem

# public/assets/emojis/*

webrtc/livekit.yaml
webrtc/docker-compose.yml

tmp/*

# Playwright test output
playwright-report/
test-results/
tests/e2e/.auth/

# HAR debug files
*.har

# Cursor agent session data (rules, plans, etc.) - exclude entire directory from public history
.cursor/
