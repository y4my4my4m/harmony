# =============================================================================
# Harmony self-host .env  (reference)
# =============================================================================
# You normally DON'T write this by hand - run `bash configure.sh`, which
# generates this file plus federation.env and supabase/.env with strong random
# secrets. This example just documents what configure.sh produces.
# =============================================================================

# Public domain of your instance (the app lives at https://DOMAIN).
DOMAIN=chat.example.com

# Supabase API gateway is served on this subdomain (https://DB_DOMAIN).
DB_DOMAIN=db.chat.example.com

# LiveKit (voice) subdomain - only used when the `voice` profile is running.
LIVEKIT_DOMAIN=live.chat.example.com

INSTANCE_NAME=Harmony

# TLS for Caddy: either a contact email (public Let's Encrypt certificates)
# or the literal word "internal" (Caddy's local CA, for LAN/NAS without DNS).
CADDY_TLS=admin@example.com

# --- Frontend build-time config (Vite inlines these) -------------------------
VITE_SUPABASE_URL=https://db.chat.example.com
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...   # generated by configure.sh
VITE_LIVEKIT_URL=
VITE_ENABLE_FEDERATION=true
VITE_ENABLE_VOICE=false
VITE_ENABLE_E2E_ENCRYPTION=true

# --- Shared secrets ----------------------------------------------------------
REDIS_PASSWORD=change-me   # generated by configure.sh
