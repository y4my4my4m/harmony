{
  "name": "harmony",
  "version": "1.3.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "npm run build:background-manifest && vite build",
    "build:background-manifest": "node scripts/build-background-manifest.mjs",
    "move:backgrounds": "node scripts/move-background-images.mjs",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "npx playwright test",
    "dev:audio-pack": "vite --config dev/audio-pack-studio/vite.config.ts",
    "test:federation": "cd federation-backend && npx vitest run",
    "test:all": "vitest run && vitest run --config vitest.db.config.ts && vitest run --config vitest.integration.config.ts && cd federation-backend && npx vitest run",
    "tauri": "tauri",
    "tauri:dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1 tauri dev",
    "tauri:dev:prod": "WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev --config src-tauri/tauri.prod.conf.json",
    "tauri:dev:windows": "tauri dev --target x86_64-pc-windows-gnu",
    "tauri:dev:windows:prod": "tauri dev --target x86_64-pc-windows-gnu --config src-tauri/tauri.prod.conf.json",
    "tauri:dev:x11": "GDK_BACKEND=x11 WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1 tauri dev",
    "tauri:dev:x11:prod": "GDK_BACKEND=x11 WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1 tauri dev --config src-tauri/tauri.prod.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:prod": "WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri build --config src-tauri/tauri.prod.conf.json",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-gnu",
    "tauri:build:windows:prod": "tauri build --target x86_64-pc-windows-gnu --config src-tauri/tauri.prod.conf.json",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "docs:generate": "typedoc --options typedoc.json",
    "docs:generate-components": "node scripts/generate-component-docs.mjs",
    "docs:generate-api": "node scripts/generate-api-docs.mjs",
    "docs:generate-guide": "node scripts/generate-guide-docs.mjs",
    "docs:sync-config": "node scripts/sync-vitepress-config.mjs",
    "docs:generate-all": "npm run docs:generate-guide && npm run docs:generate-components && npm run docs:generate-api && npm run docs:sync-config && npm run docs:generate && npm run docs:build",
    "docs:watch": "concurrently \"npm run docs:generate-components -- --watch\" \"npm run docs:generate-api -- --watch\" \"npm run docs:dev\"",
    "docs:serve": "cd docs/api && python -m http.server 8080",
    "docs:lint": "markdownlint docs/**/*.md",
    "docs:fix": "markdownlint docs/**/*.md --fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:legacy": "concurrently \"npm run docs:generate -- --watch\" \"npm run docs:serve\""
  },
  "dependencies": {
    "@privacyresearch/libsignal-protocol-typescript": "^0.0.16",
    "@supabase/supabase-js": "^2.84.0",
    "@tanstack/vue-virtual": "^3.13.21",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@types/qrcode": "^1.5.6",
    "@vueuse/core": "^10.7.2",
    "@yeger/vue-masonry-wall": "^5.0.5",
    "date-fns": "^3.2.0",
    "discord.js": "^14.14.1",
    "dompurify": "^3.3.3",
    "jszip": "^3.10.1",
    "livekit-client": "^2.6.2",
    "lucide-vue-next": "^0.577.0",
    "mediasoup-client": "^3.7.2",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.4",
    "simple-icons": "^14.0.0",
    "simple-peer": "^9.11.1",
    "uuid": "^11.1.0",
    "vue": "^3.3.11",
    "vue-drag-drop": "^1.1.4",
    "vue-easy-lightbox": "^1.17.0",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.5",
    "vue-toastification": "^2.0.0-rc.5",
    "vue3-lazyload": "^0.3.8",
    "vuedraggable": "^4.1.0",
    "ws": "^8.16.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.52.8",
    "@playwright/test": "^1.58.2",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tauri-apps/cli": "^2.0.0",
    "@tsconfig/node18": "^18.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^18.19.119",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.0",
    "concurrently": "^8.2.2",
    "dotenv": "^17.3.1",
    "eslint": "^8.49.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^9.17.0",
    "fake-indexeddb": "^6.2.5",
    "gemoji": "^8.1.0",
    "glob": "^11.0.3",
    "happy-dom": "^20.9.0",
    "jsdoc-to-markdown": "^9.1.1",
    "markdownlint-cli": "^0.48.0",
    "mermaid": "^11.9.0",
    "msw": "^2.12.10",
    "npm-run-all2": "^6.1.1",
    "prettier": "^3.0.3",
    "supabase": "^2.83.0",
    "typedoc": "^0.25.7",
    "typedoc-plugin-mermaid": "^1.10.0",
    "typedoc-plugin-vue": "^1.2.0",
    "typescript": "~5.3.0",
    "unicode-emoji-json": "^0.8.0",
    "vite": "^5.0.10",
    "vite-plugin-html-minifier": "^1.0.5",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^2.1.9",
    "vue-docgen-api": "^4.79.2",
    "vue-docgen-cli": "^4.79.0",
    "vue-tsc": "^2.2.12"
  },
  "overrides": {
    "minimatch": "^9.0.7"
  }
}
