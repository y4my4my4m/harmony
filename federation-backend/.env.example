# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Supabase Configuration (Self-hosted from harmonious Docker)
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Instance Configuration
INSTANCE_DOMAIN=localhost:5173
INSTANCE_NAME=Harmony
INSTANCE_DESCRIPTION=Development instance of Harmony

# Redis Configuration (optional for now)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

VAPID_PUBLIC_KEY=BPxxxx...
VAPID_PRIVATE_KEY=xxxx...
VAPID_SUBJECT=admin@yourdomain.com


USE_BULLMQ_QUEUE=true

# Optional: direct session-mode Postgres connection for instant LISTEN/NOTIFY
# job pickup. Use the least-privilege harmony_listener role (NOT the superuser).
# If omitted, jobs are still processed by the periodic sweep.
FEDERATION_LISTENER_URL=postgresql://harmony_listener:XXXXX@supabase-db:5432/postgres

# LiveKit Configuration
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Set mode to 'sfu' to force LiveKit, or 'hybrid' for fallback
WEBRTC_MODE=sfu

# Klipy GIF provider (replaces Tenor). Keys stay on the backend so they never
# reach the browser. Two keys let supporters skip ads:
#   - KLIPY_API_KEY_ADS   : key with ads ENABLED in the Klipy dashboard (regular users)
#   - KLIPY_API_KEY_NOADS : key with ads DISABLED (served to ad-free supporter tiers)
# Set only one to use it for everyone. Leave both blank to disable GIF search.
KLIPY_API_KEY_ADS=
KLIPY_API_KEY_NOADS=
# KLIPY_BASE_URL=https://api.klipy.com