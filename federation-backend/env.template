# =============================================================================
# Harmony Federation Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001

# API base URL (usually http://localhost:3001 or your public URL)
API_BASE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from your Supabase project: Settings > API

# Supabase URL (API base - Kong/PostgREST, not direct Postgres)
# Use the URL that resolves from where this process runs:
# - Running on host (pm2/node): use public URL, e.g. https://db.yourdomain.com
# - Running in Docker on same network as Supabase: use http://supabase-kong:8000
# For Supabase Cloud: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Anonymous key (public, safe to expose)
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SECRET - never expose to frontend!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Public Supabase URL (if different from internal URL)
# Useful when federation backend accesses Supabase internally via Docker
# but needs to generate public URLs for federation
# PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# -----------------------------------------------------------------------------
# Database URL (REQUIRED if USE_BULLMQ_QUEUE=true)
# -----------------------------------------------------------------------------
# Used for LISTEN/NOTIFY bridge from DB triggers to BullMQ.
# Must be a SESSION-mode connection (port 5432) - LISTEN/NOTIFY does not
# work over transaction-mode poolers.
#
# For Supabase Cloud:
#   Dashboard → Project Settings → Database → Connection string (Session mode)
#   Example: DATABASE_URL=postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:5432/postgres
#
# For Self-hosted Supabase (Docker network):
#   DATABASE_URL=postgresql://postgres:your-password@supabase-db:5432/postgres
#
# Leave empty ONLY if USE_BULLMQ_QUEUE=false
DATABASE_URL=

# Pooled connection URL (Supavisor transaction mode, port 6543) - recommended
# Pools many logical connections into a small number of real PG connections,
# removing the PostgreSQL connection limit as a bottleneck.
# Falls back to DATABASE_URL if not set.
#
# Self-hosted: postgresql://postgres:PASSWORD@supabase-pooler:6543/postgres
# Cloud:       postgresql://postgres.[ref]:[password]@[region].pooler.supabase.com:6543/postgres
DATABASE_POOL_URL=

# -----------------------------------------------------------------------------
# Instance Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Your instance's public domain (without https://)
# This is used for generating ActivityPub URLs
INSTANCE_DOMAIN=harmony.example.com

# Instance display name (shown in federation)
INSTANCE_NAME=Harmony

# Instance description (shown in NodeInfo)
INSTANCE_DESCRIPTION=A federated social platform

# -----------------------------------------------------------------------------
# Security & CORS (REQUIRED)
# -----------------------------------------------------------------------------
# CORS origins (comma-separated if multiple)
# Your frontend URL(s)
CORS_ORIGIN=https://harmony.example.com

# JWT secret (optional - used for validating Supabase JWTs)
# JWT_SECRET=

# Federation security: require valid HTTP signatures
# Set to 'false' only for testing (not recommended in production)
REQUIRE_VALID_SIGNATURES=true

# -----------------------------------------------------------------------------
# LiveKit WebRTC (OPTIONAL - for voice/video)
# -----------------------------------------------------------------------------
# Generate keys with: openssl rand -hex 32

# LiveKit API credentials
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit WebSocket URL (internal, for backend to connect)
# Local: ws://localhost:7880
# Docker: ws://harmony-livekit:7880
LIVEKIT_URL=ws://localhost:7880

# LiveKit public URL (what clients use)
# LIVEKIT_PUBLIC_URL=wss://live.harmony.example.com

# WebRTC mode: sfu (LiveKit), p2p (peer-to-peer), hybrid (sfu with p2p fallback)
WEBRTC_MODE=hybrid

# Allow voice/video calls with users on other instances
ALLOW_FEDERATED_VOICE=true

# -----------------------------------------------------------------------------
# Email / SMTP (OPTIONAL but recommended)
# -----------------------------------------------------------------------------
# Used for sending notification emails, reports, etc.
# Supabase Auth emails are configured separately in Supabase Dashboard.
#
# Recommended: Use Resend (https://resend.com) - 3,000 emails/month free
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=re_your_api_key
#   SMTP_FROM=notifications@yourdomain.com
#
# Other options: SendGrid, Mailgun, AWS SES, or any SMTP server

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notifications@harmony.example.com
SMTP_SECURE=true

# -----------------------------------------------------------------------------
# Push Notifications (OPTIONAL)
# -----------------------------------------------------------------------------
# Generate VAPID keys with: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@harmony.example.com

# -----------------------------------------------------------------------------
# Queue Processing
# -----------------------------------------------------------------------------
# BullMQ (Redis-backed) handles federation with retries, backoff, and a
# monitoring dashboard at /admin/queues.  Requires REDIS_URL and DATABASE_URL.
#
# When true:  Uses BullMQ + LISTEN/NOTIFY bridge (recommended)
# When false: Uses legacy Supabase Realtime triggers (simpler but less reliable)
#
# For quick start: Set to false if you don't have Redis/DATABASE_URL configured
# For production:  Set to true and configure both REDIS_URL and DATABASE_URL
USE_BULLMQ_QUEUE=true

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Redis (REQUIRED for BullMQ, caching, presence, rate limiting)
# -----------------------------------------------------------------------------
# Shared with LiveKit if voice is enabled.
# Docker: redis://:PASSWORD@redis:6379
# Local:  redis://localhost:6379
REDIS_URL=redis://localhost:6379

