{
  "name": "harmony-federation-backend",
  "version": "1.2.0",
  "description": "Harmony federated social platform - ActivityPub Federation Backend (FEDERATION ONLY)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:server": "FEDERATION_MODE=server tsx watch src/index.ts",
    "dev:worker": "FEDERATION_MODE=worker tsx watch src/index.ts",
    "build": "tsc",
    "build-only": "tsc --skipLibCheck || true",
    "start": "node dist/index.js",
    "start:server": "FEDERATION_MODE=server node dist/index.js",
    "start:worker": "FEDERATION_MODE=worker node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "diagnose": "tsx diagnose-federation.ts",
    "diagnose-deep": "tsx diagnose-deep.ts",
    "check-remote": "tsx check-remote-users.ts",
    "check-misskey": "tsx check-misskey-follows.ts",
    "refresh-users": "tsx refresh-remote-users.ts",
    "backfill-posts": "tsx backfill-posts.ts"
  },
  "keywords": [
    "activitypub",
    "federation",
    "fediverse",
    "mastodon",
    "misskey"
  ],
  "author": "",
  "license": "AGPL-3.0",
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "bullmq": "^5.71.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "livekit-server-sdk": "^2.9.1",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "undici": "^6.24.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
