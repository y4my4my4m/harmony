# =============================================================================
# LiveKit Server Configuration
# =============================================================================

# API Key and Secret for LiveKit authentication
# Generate with: openssl rand -hex 32
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=ayBT3S4vMZQ8P2xKf9WnL6jR_hDcEaaaaAAA333cccaAcaAc

# LiveKit WebSocket URL (for internal connections)
# Development: ws://localhost:7880 or ws://harmony-livekit:7880 (from Docker)
# Production: ws://livekit-internal:7880
LIVEKIT_URL=ws://localhost:7880

# =============================================================================
# Public-facing URLs
# =============================================================================

# Your instance's public domain
# Development: har.mony.local
# Production: yourdomain.com
INSTANCE_DOMAIN=har.mony.local

# Public LiveKit WebSocket URL (what clients connect to)
# Development: wss://live.mony.local
# Production: wss://live.yourdomain.com
LIVEKIT_PUBLIC_URL=wss://live.mony.local

# =============================================================================
# TURN Server Configuration (NAT Traversal)
# =============================================================================
# LiveKit includes a built-in TURN server.
# For most users behind NAT, TURN is essential for connectivity.

# TURN server domain
# Development: localhost (uses built-in TURN)
# Production: turn.yourdomain.com or live.yourdomain.com
TURN_DOMAIN=localhost

# External TURN credentials (only if using external TURN like coturn)
# TURN_USERNAME=
# TURN_PASSWORD=

# =============================================================================
# Redis Configuration
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# =============================================================================
# Egress (Recording) Configuration
# =============================================================================

# Enable egress service for recording/streaming
# Start with: docker compose --profile egress up -d
ENABLE_EGRESS=false

# S3 storage for recordings (production)
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-west-2
# S3_BUCKET=harmony-recordings

# =============================================================================
# Performance Tuning
# =============================================================================

# Maximum participants per room (0 = unlimited)
MAX_PARTICIPANTS=0

# Room empty timeout (seconds) - room closes after this duration with no participants
EMPTY_ROOM_TIMEOUT=300

# =============================================================================
# Security
# =============================================================================

# Webhook secret for validating callbacks
# WEBHOOK_SECRET=

# Token TTL (seconds) - how long room tokens are valid
TOKEN_TTL=86400
