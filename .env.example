# =============================================================================
# Harmony Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# For LOCAL DEVELOPMENT: use the defaults below (pointing to local Supabase).
# For PRODUCTION: update all values to match your deployment.
#
# Tip: Run `bash scripts/install.sh` for interactive setup.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from your Supabase project: Settings > API
# Local dev default uses the Supabase demo anon key
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=

# Optional: if storage uses a different domain (e.g. db.example.com) than VITE_SUPABASE_URL,
# add it here so emoji/imgproxy transforms work. Comma-separated for multiple.
# VITE_STORAGE_DOMAIN=db.example.com

# -----------------------------------------------------------------------------
# Instance Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Your instance's public domain (without https://)
VITE_INSTANCE_DOMAIN=har.mony.local

# Instance display name
VITE_INSTANCE_NAME=Harmony

# Domain used for ActivityPub handles and federation (without https://)
# Usually the same as VITE_INSTANCE_DOMAIN
VITE_DOMAIN=har.mony.local

# App URL (used for CORS and redirects)
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Federation Backend (OPTIONAL but recommended)
# -----------------------------------------------------------------------------
# URL to the federation backend for link previews and ActivityPub
# Usually same as your domain if using nginx reverse proxy
VITE_FEDERATION_API_URL=https://harmony.example.com

# -----------------------------------------------------------------------------
# LiveKit WebRTC (OPTIONAL - for voice/video)
# -----------------------------------------------------------------------------
# LiveKit WebSocket URL for voice/video calls
# Leave empty to disable voice/video features
VITE_LIVEKIT_URL=wss://live.harmony.example.com

# -----------------------------------------------------------------------------
# Feature Flags (OPTIONAL)
# -----------------------------------------------------------------------------
# Set VITE_ENABLE_FEDERATION=false if you're NOT running federation-backend
VITE_ENABLE_FEDERATION=true
VITE_ENABLE_VOICE=true
VITE_ENABLE_E2E_ENCRYPTION=true

# -----------------------------------------------------------------------------
# Legal Pages (OPTIONAL)
# -----------------------------------------------------------------------------
# Shown on the registration page. Can also be set via the admin panel.
# Leave empty to hide the links.
# VITE_TERMS_URL=https://example.com/terms
# VITE_PRIVACY_URL=https://example.com/privacy

# -----------------------------------------------------------------------------
# API Keys (OPTIONAL)
# -----------------------------------------------------------------------------
# Tenor GIF API key (for GIF picker)
VITE_TENOR_API_KEY=

# -----------------------------------------------------------------------------
# Redis (shared by LiveKit, federation-backend, and app caching)
# -----------------------------------------------------------------------------
# Generated by install.sh - must match docker-compose and webrtc/livekit.yaml
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# LiveKit Voice/Video (OPTIONAL)
# -----------------------------------------------------------------------------
# LiveKit uses UDP mux (port 7882) - all WebRTC media on a single port.
# No port range variables needed. See webrtc/livekit.yaml for details.

# -----------------------------------------------------------------------------
# Bull Board - Queue Monitoring Dashboard (OPTIONAL)
# -----------------------------------------------------------------------------
# Only needed if you enable the monitoring profile:
#   docker compose --profile monitoring up -d
# Access at http://your-server:3003
# BULL_BOARD_USER=admin
# BULL_BOARD_PASSWORD=

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------
# Only for local development - don't use in production
VITE_DEBUG_LOGGING=false
# VITE_DEV_SKIP_AUTH=false
