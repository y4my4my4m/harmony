# Integration test environment configuration
# Copy to .env.test and adjust values for your local Supabase instance

# Supabase API (via Kong gateway)
TEST_SUPABASE_URL=http://localhost:8000
TEST_SUPABASE_ANON_KEY=your-anon-key-here
TEST_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct PostgreSQL connection (requires DB port exposed in harmonious/docker-compose.yml)
TEST_DATABASE_URL=postgresql://postgres:your-super-secret-and-long-postgres-password@localhost:54322/postgres
