# =====================================================
# Bot Gateway Environment Configuration
# =====================================================

# Internal Supabase URL (can be localhost for efficiency)
# Used for database queries, RLS, and internal operations
SUPABASE_URL=http://localhost:8000

# Service role key for bypassing RLS policies
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public-facing URL for external services
# Used for avatars, attachments, and other public resources
# This should be your production domain for external services like Discord
PUBLIC_URL=https://your-public-domain.com

# Server configuration
PORT=3002
NODE_ENV=development
