# =============================================================================
# Harmony Bot Gateway Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3002

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from your Supabase project: Settings > API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Instance Configuration
# -----------------------------------------------------------------------------
INSTANCE_DOMAIN=harmony.example.com

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# CORS origins (your frontend URL)
CORS_ORIGIN=https://harmony.example.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Bot-Specific Configuration
# -----------------------------------------------------------------------------
# Maximum concurrent bot connections
MAX_BOT_CONNECTIONS=100

# Heartbeat interval in milliseconds
HEARTBEAT_INTERVAL=30000

# Connection timeout in milliseconds
CONNECTION_TIMEOUT=60000

